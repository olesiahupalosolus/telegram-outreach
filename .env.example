# Copy this file to .env and fill in real values.
# .env is gitignored and will NOT be committed.

# Flask secret key — generate a random string, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# Database connection.
# On Railway: leave empty — Railway auto-injects DATABASE_URL when you attach a Postgres plugin.
# Locally: leave empty to use sqlite (a file `app.db` will be created next to app.py).
# Manual override example:
#   DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DATABASE_URL=

# Optional: port for local dev (Railway sets this automatically)
PORT=8080
